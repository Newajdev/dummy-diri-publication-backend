generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Article {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  pdfUrl    String
  audioUrl  String
  qrCodeUrl String
  content   String   @default("") @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
